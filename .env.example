# Supabase project (Settings → API Keys / "Connect" button)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Postgres (Settings → Database → "Connect" → Transaction pooler / Session pooler)
# DATABASE_URL: pooled (Transaction mode, port 6543, ?pgbouncer=true) — used by the app at runtime
# DIRECT_URL:  Session pooler (port 5432) — used by Drizzle for migrations and policy scripts
DATABASE_URL=
DIRECT_URL=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated whitelist of authorized emails (Nico, Pau).
# Validated server-side in the magic-link action; non-listed emails get a
# fake-success response so the form does not leak which addresses exist.
ALLOWED_EMAILS=
