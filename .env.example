# Supabase project (Settings → API Keys / "Connect" button)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Postgres (Settings → Database → "Connect" → Transaction pooler / Session pooler)
# DATABASE_URL: pooled (Transaction mode, port 6543, ?pgbouncer=true) — used by the app at runtime
# DIRECT_URL:  Session pooler (port 5432) — used by Drizzle for migrations and policy scripts
DATABASE_URL=
DIRECT_URL=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated whitelist of authorized emails (Nico, Pau).
# Validated server-side in the magic-link action; non-listed emails get a
# fake-success response so the form does not leak which addresses exist.
ALLOWED_EMAILS=

# Vercel Cron — secret shared between Vercel and our route handlers.
# Generate with `openssl rand -hex 32`. Vercel inyecta este valor como
# `Authorization: Bearer <CRON_SECRET>` cuando dispara los crons.
CRON_SECRET=

# idVariable BCRA para el tipo de cambio minorista (Comunicación B 9791).
# Descubrirlo con `npm run fx:list-vars`. Si querés cambiar a mayorista
# (Comunicación A 3500), también va acá.
BCRA_FX_MINORISTA_VARIABLE_ID=

# Anthropic API — parser de imports (PRD §5.2). Sonnet 4-6 default,
# Haiku 4-5 para modo barato. Solo server-side.
ANTHROPIC_API_KEY=
IMPORT_PARSER_MODEL_DEFAULT=claude-sonnet-4-6
IMPORT_PARSER_MODEL_CHEAP=claude-haiku-4-5-20251001

# Google Drive (Hito 10 — backups). OAuth user credentials con refresh
# token: service accounts no tienen storage quota en cuentas personales
# gmail.com, así que el cron sube los .zip "como tu usuario" usando un
# refresh token de larga duración. Setup en STATUS.md.
#   1. GCP Console → OAuth consent screen (External, publish).
#   2. Credentials → OAuth Client ID (Desktop app) → copiar id+secret.
#   3. npm run oauth:drive-token → autorizás en browser → script imprime
#      el refresh token (también lo escribe a .env.local).
# GOOGLE_DRIVE_BACKUP_FOLDER_ID es el último segmento de la URL de la
# carpeta en Drive donde el cron sube los .zip.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_BACKUP_FOLDER_ID=

# Módulo Calendario de Licitaciones (dominio de Pau, reusa infra de gd-finanzas).
# Microservicio Python (FastAPI envuelve procesar.py) deployado en Railway/Render.
#   LICITACIONES_SERVICE_URL: URL pública del microservicio (sin barra final).
#   LICITACIONES_SERVICE_SECRET: secreto compartido (mismo valor en ambos lados),
#     viaja como `Authorization: Bearer <secret>`. Generar con `openssl rand -hex 32`.
# El microservicio tiene su propio ANTHROPIC_API_KEY y LICITACIONES_MODEL.
LICITACIONES_SERVICE_URL=
LICITACIONES_SERVICE_SECRET=
