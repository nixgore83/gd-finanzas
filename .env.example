# Supabase project (Settings → API Keys / "Connect" button)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Postgres (Settings → Database → "Connect" → Transaction pooler / Session pooler)
# DATABASE_URL: pooled (Transaction mode, port 6543, ?pgbouncer=true) — used by the app at runtime
# DIRECT_URL:  Session pooler (port 5432) — used by Drizzle for migrations and policy scripts
DATABASE_URL=
DIRECT_URL=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated whitelist of authorized emails (Nico, Pau).
# Validated server-side in the magic-link action; non-listed emails get a
# fake-success response so the form does not leak which addresses exist.
ALLOWED_EMAILS=

# Vercel Cron — secret shared between Vercel and our route handlers.
# Generate with `openssl rand -hex 32`. Vercel inyecta este valor como
# `Authorization: Bearer <CRON_SECRET>` cuando dispara los crons.
CRON_SECRET=

# idVariable BCRA para el tipo de cambio minorista (Comunicación B 9791).
# Descubrirlo con `npm run fx:list-vars`. Si querés cambiar a mayorista
# (Comunicación A 3500), también va acá.
BCRA_FX_MINORISTA_VARIABLE_ID=

# Anthropic API — parser de imports (PRD §5.2). Sonnet 4-6 default,
# Haiku 4-5 para modo barato. Solo server-side.
ANTHROPIC_API_KEY=
IMPORT_PARSER_MODEL_DEFAULT=claude-sonnet-4-6
IMPORT_PARSER_MODEL_CHEAP=claude-haiku-4-5-20251001

# Google Drive (Hito 10 — backups). Setup operacional documentado en
# STATUS.md. La key del service account va base64-encoded (porque
# multi-line JSON no juega bien con .env ni Vercel UI).
#   base64 -i sa-key.json | tr -d '\n' | pbcopy
# GOOGLE_DRIVE_BACKUP_FOLDER_ID es el último segmento de la URL de la
# carpeta en Drive (compartida con el SA email con rol Editor).
GOOGLE_SERVICE_ACCOUNT_KEY_B64=
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
